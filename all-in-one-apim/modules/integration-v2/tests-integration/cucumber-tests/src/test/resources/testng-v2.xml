<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  Integration test suite for the parallel-on-shared-container (v2) lane. Each <test> block boots one APIM
  container (BlockLifecycleListener.onStart) shared by all its classes; blocks run in parallel up to the
  suite thread-count. Real integration tests are added as <test> blocks (or as classes within an existing
  same-config block) as they are rewritten onto BaseBlockRunner. The legacy testng.xml is never referenced;
  this suite is selected via -Dsurefire.suite.xml=testng-v2.xml. K (concurrent blocks/containers) is set
  here via thread-count, not via profile env. (Lane boot itself is covered by the framework-verification
  suites — no placeholder block is kept here, since the product runners exercise the same lane.)
-->
<suite name="Integration Tests v2" parallel="tests" thread-count="2">
    <listeners>
        <listener class-name="org.wso2.am.integration.cucumbertests.utils.listeners.BlockLifecycleListener"/>
        <listener class-name="org.wso2.am.integration.cucumbertests.utils.listeners.BlockScopeListener"/>
        <!-- No-op unless -Dapim.coverage=true; then merges per-block JaCoCo dumps into one report at suite end. -->
        <listener class-name="org.wso2.am.integration.cucumbertests.utils.listeners.CoverageAggregationListener"/>
    </listeners>
    <!-- Publisher features sharing the default container config run as parallel classes in one block,
         so a single container boots for all of them instead of one boot per feature. Split into a second
         block only when this one accumulates too many classes for the block's thread-count, or when a
         feature needs a different container config (then it gets its own block). -->
    <test name="IntegrationV2-Publisher" parallel="classes" thread-count="2">
        <parameter name="blockLabel" value="publisher"/>
        <parameter name="initTenantUsers" value="true"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.PublisherVersioningRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.PublisherLifecycleRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.PublisherConfigRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.PublisherOperationPoliciesRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.PublisherScopesRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.PublisherDefinitionsRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.PublisherDocsRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.PublisherGraphQLDesignRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.PublisherSoapDesignRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.PublisherAPIRevisionsRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.PublisherApiProductsRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.PublisherAccessControlRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.PublisherApiProviderChangeRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.PublisherDefaultEndpointRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.PublisherEndpointCertificatesRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.PublisherServiceCatalogRunner"/>
        </classes>
    </test>
    <!-- Streaming design (WebSocket + AsyncAPI import) needs the NEW AsyncAPI parser: the v2 default is the legacy
         parser, which does NOT enforce strict AsyncAPI-v2 validation (e.g. an implicit OAuth flow missing its
         authorization URL is silently accepted). The overlay sets [apim.publisher] use_legacy_async_parser=false
         so the v2/v3 validation matches AsyncAPITestWithValidationCase. Own block per the config-overlay rule. -->
    <test name="IntegrationV2-PublisherStreamingDesign" parallel="classes" thread-count="1">
        <parameter name="blockLabel" value="publisher-streaming-design"/>
        <parameter name="initTenantUsers" value="true"/>
        <parameter name="tomlExtraOverlayPath" value="src/test/resources/artifacts/configFiles/asyncParser/deployment.toml"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.PublisherStreamingDesignRunner"/>
        </classes>
    </test>
    <!-- DevPortal features share their own container (separate capability, consumer-plane actors). -->
    <test name="IntegrationV2-DevPortal" parallel="classes" thread-count="2">
        <parameter name="blockLabel" value="devportal"/>
        <parameter name="initTenantUsers" value="true"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.DevPortalApplicationsRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.DevPortalSearchRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.DevPortalSubscriptionManagementRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.DevPortalSubscribeRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.DevPortalSdkGenerationRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.DevPortalVisibilityRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.DevPortalCommentsRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.DevPortalRatingsRunner"/>
        </classes>
    </test>
    <!-- Gateway features (runtime invocation) share their own container. -->
    <test name="IntegrationV2-Gateway" parallel="classes" thread-count="2">
        <parameter name="blockLabel" value="gateway"/>
        <parameter name="initTenantUsers" value="true"/>
        <parameter name="initBackend" value="true"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewayRestInvocationRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewaySoapInvocationRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewayGraphQLInvocationRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewaySecurityEnforcementRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewayThrottlingEnforcementRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewayGraphQLScopeEnforcementRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewayDefaultVersionRoutingRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewayLifecycleStageInvocationRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewayApiProductInvocationRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewayGraphqlQueryLimitsRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewayGraphqlEndpointSecurityRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.PublisherGraphqlFromUrlRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewayAiApiInvocationRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewayPrototypeApiRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewaySchemaValidationRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewayWebSocketInvocationRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewayGraphQLSubscriptionRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewayGraphqlSubscriptionThrottlingRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewayGraphqlSubQueryLimitsRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewayCorsRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewayMediationPoliciesRunner"/>
            <!-- MCP servers (publisher-plane create/CRUD + gateway-plane invocation): both need the node
                 mcp-server backend, which this block already starts, so they run here rather than in a separate
                 backend-enabled block. -->
            <class name="org.wso2.am.integration.cucumbertests.runners.block.PublisherMcpServersRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewayMcpInvocationRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewayAudienceValidationRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewayRestArtifactsRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewayDefaultEndpointInvocationRunner"/>
        </classes>
    </test>
    <!-- Mutual-SSL invocation + WebSocket CORS share ONE block: their overlays are orthogonal (mTLS shrinks the
         SSL-profile read interval with client auth still "optional"; WS-CORS enables the WS origin allow-list —
         different TOML tables, neither breaks the other's flows), so they co-locate on one container instead of
         two. Needs the node backend. Runs the two runners as parallel classes (thread-count=2): they use
         different data planes — mTLS on the 8243 HTTPS passthrough, WS-CORS on the ws:// inbound — so they don't
         interfere. -->
    <test name="IntegrationV2-MutualSslWsCors" parallel="classes" thread-count="2">
        <parameter name="blockLabel" value="mtls-ws-cors"/>
        <parameter name="initTenantUsers" value="true"/>
        <parameter name="initBackend" value="true"/>
        <parameter name="tomlExtraOverlayPath" value="src/test/resources/artifacts/configFiles/mtlsWsCors/deployment.toml"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewayMutualSslInvocationRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewayWebSocketCorsRunner"/>
        </classes>
    </test>
    <!-- Key-manager features (token/key issuance). initBackend for the refresh/sandbox gateway invocations. -->
    <test name="IntegrationV2-KeyManager" parallel="classes" thread-count="2">
        <parameter name="blockLabel" value="keymanager"/>
        <parameter name="initTenantUsers" value="true"/>
        <parameter name="initBackend" value="true"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.KeyManagerTokenIssuanceRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.KeyManagerTokenRevocationRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.KeyManagerApiKeyRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.KeyManagerOAuthKeysRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.KeyManagerMultipleClientSecretsRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.KeyManagerMapApplicationKeysRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.KeyManagerApplicationRevocationRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.KeyManagerJwtGrantRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.KeyManagerPkceKeysRunner"/>
        </classes>
    </test>
    <!-- Features needing extra (non-default) server config share one container via a feature-specific TOML
         overlay (tomlExtraOverlayPath, merged on top of basic): a custom gateway auth header and devportal
         application sharing. Their config is orthogonal, so they co-locate; initBackend for the custom-auth
         gateway invocation. -->
    <test name="IntegrationV2-CustomAuthHeaderAndAppSharing" parallel="classes" thread-count="2">
        <parameter name="blockLabel" value="custom-auth-sharing"/>
        <parameter name="initTenantUsers" value="true"/>
        <parameter name="initBackend" value="true"/>
        <parameter name="tomlExtraOverlayPath" value="src/test/resources/artifacts/configFiles/customAuthHeaderAndAppSharing/deployment.toml"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewayCustomAuthHeaderRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.DevPortalApplicationSharingRunner"/>
        </classes>
    </test>
    <!-- Custom application attributes: needs a feature-specific overlay (backend JWT generation + a declared
         application attribute) and a backend (the header-reflecting /reflect-headers route) so the attribute
         can be verified both stored and surfaced in the X-JWT-Assertion backend JWT claim. Its own block
         because the overlay ([apim.jwt] enable, application_attributes required=true) is not orthogonal to
         other blocks' config. -->
    <test name="IntegrationV2-ApplicationAttributes" parallel="classes" thread-count="1">
        <parameter name="blockLabel" value="application-attributes"/>
        <parameter name="initTenantUsers" value="true"/>
        <parameter name="initBackend" value="true"/>
        <parameter name="tomlExtraOverlayPath" value="src/test/resources/artifacts/configFiles/applicationAttributes/deployment.toml"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.DevPortalApplicationAttributesRunner"/>
            <!-- Backend-JWT claims co-locate here: the same overlay enables [apim.jwt], the block starts the node
                 backend (/reflect-headers), and both create apps that supply the required application attribute. -->
            <class name="org.wso2.am.integration.cucumbertests.runners.block.KeyManagerBackendJwtRunner"/>
        </classes>
    </test>
    <!-- Backend-JWT URL-safe encoding: its own block because [apim.jwt] encoding = base64url is a gateway-wide
         setting that would change the base64 encoding the ApplicationAttributes block relies on. Needs the node
         backend (/reflect-headers). -->
    <test name="IntegrationV2-BackendJwtUrlSafe" parallel="classes" thread-count="1">
        <parameter name="blockLabel" value="backend-jwt-urlsafe"/>
        <parameter name="initTenantUsers" value="true"/>
        <parameter name="initBackend" value="true"/>
        <parameter name="tomlExtraOverlayPath" value="src/test/resources/artifacts/configFiles/backendJwtUrlSafe/deployment.toml"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.KeyManagerBackendJwtUrlSafeRunner"/>
        </classes>
    </test>

    <test name="IntegrationV2-SandboxGateway" parallel="classes" thread-count="1">
        <parameter name="blockLabel" value="sandbox-gateway"/>
        <parameter name="initTenantUsers" value="true"/>
        <parameter name="initBackend" value="true"/>
        <parameter name="tomlExtraOverlayPath" value="src/test/resources/artifacts/configFiles/sandboxGateway/deployment.toml"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewaySandboxEnvRunner"/>
        </classes>
    </test>
    <!-- Conditional-group advanced throttling enforcement (IP/header/query/JWT-claim). Its overlay enables the
         header/query/JWT-claim throttling flags (off by default). Needs the backend for gateway invocation.
         thread-count=1: throttle enforcement is timing-sensitive, so no sibling class shares the container. -->
    <test name="IntegrationV2-ConditionalThrottling" parallel="classes" thread-count="1">
        <parameter name="blockLabel" value="conditional-throttling"/>
        <parameter name="initTenantUsers" value="true"/>
        <parameter name="initBackend" value="true"/>
        <parameter name="tomlExtraOverlayPath" value="src/test/resources/artifacts/configFiles/conditionalThrottling/deployment.toml"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.ConditionalThrottlingRunner"/>
        </classes>
    </test>
    <!-- Admin-plane governance/policy tests (default config, no gateway backend). Concurrent block. -->
    <test name="IntegrationV2-Admin" parallel="classes" thread-count="2">
        <parameter name="blockLabel" value="admin"/>
        <parameter name="initTenantUsers" value="true"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.AdminApplicationSearchRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.AdminThrottlingPolicyRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.AdminGatewayEnvironmentsRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.AdminKeyManagerConfigRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.AdminDenyPolicyRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.AdminTenantConfigRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.AdminSystemScopesRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.AdminThrottlePolicyExportImportRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.AdminApiCategoriesRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.AdminApplicationOwnerChangeRunner"/>
        </classes>
    </test>
    <!-- B2B organization visibility. Own block: registers the organizationId local claim (SOAP) and provisions
         org-scoped users at scenario time. Default config, no gateway backend. -->
    <test name="IntegrationV2-OrganizationVisibility" parallel="classes" thread-count="1">
        <parameter name="blockLabel" value="organization-visibility"/>
        <parameter name="initTenantUsers" value="true"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.AdminOrganizationVisibilityRunner"/>
        </classes>
    </test>
    <!-- API Governance plane (rulesets / policies / compliance) — its own product API (/api/am/governance/v1)
         with its own apim:gov_* token scopes. Default config (compliance evaluates API definitions, not runtime,
         so no gateway backend needed). Concurrent block. -->
    <test name="IntegrationV2-Governance" parallel="classes" thread-count="2">
        <parameter name="blockLabel" value="governance"/>
        <parameter name="initTenantUsers" value="true"/>
        <!-- initBackend: the MCP-proxy compliance scenario discovers tools from the node MCP server at create. -->
        <parameter name="initBackend" value="true"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GovernanceRulesetsRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GovernancePoliciesRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GovernanceComplianceRunner"/>
        </classes>
    </test>
    <!-- Mandatory custom API property enforcement: overlay declares a required custom property. Own block
         (the required-property config is not orthogonal to other blocks). No gateway backend needed. -->
    <test name="IntegrationV2-MandatoryProperties" parallel="classes" thread-count="1">
        <parameter name="blockLabel" value="mandatory-properties"/>
        <parameter name="initTenantUsers" value="true"/>
        <parameter name="tomlExtraOverlayPath" value="src/test/resources/artifacts/configFiles/mandatoryProperties/deployment.toml"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.PublisherMandatoryPropertiesRunner"/>
        </classes>
    </test>
    <!-- Token persistence across a graceful server restart. MUST run sequentially (thread-count=1): the
         restart step bounces the shared APIM server in place via the ServerAdmin restartGracefully API, so no
         sibling class may share this container. Overlay enables token persistence + enable_restart_from_api;
         initBackend for the gateway invocations. -->
    <test name="IntegrationV2-ServerRestart" parallel="classes" thread-count="1">
        <parameter name="blockLabel" value="server-restart"/>
        <parameter name="initTenantUsers" value="true"/>
        <parameter name="initBackend" value="true"/>
        <parameter name="tomlExtraOverlayPath" value="src/test/resources/artifacts/configFiles/serverRestart/deployment.toml"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.ServerRestartTokenPersistenceRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.ServerRestartSharedScopeRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.ServerRestartMultiProtocolRunner"/>
        </classes>
    </test>
    <!-- Remote server logging (RemoteLoggingAppenderTest). MUST run sequentially (thread-count=1): it mutates
         the shared server's log4j2.properties via the RemoteLoggingConfig admin service, so no sibling class may
         share this container. A host mock sink receives the streamed logs via host.docker.internal. -->
    <test name="IntegrationV2-RemoteLogging" parallel="classes" thread-count="1">
        <parameter name="blockLabel" value="remote-logging"/>
        <parameter name="initTenantUsers" value="true"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.RemoteLoggingRunner"/>
        </classes>
    </test>
    <!-- The SECONDARY.COM secondary user store is stood up entirely at RUNTIME (initSecondaryUserStore=true):
         the framework creates the usermgt schema in a fresh embedded H2 DB from the product's own dbscripts
         in-container, registers the store via UserStoreConfigAdminService.addUserStore (SOAP), and polls until
         the domain is active (~10s async hot-deploy). No seeded .mv.db and no serverFilesToCopy. See
         SecondaryUserStoreProvisioner + docs/devs/secondary-userstore-framework-architecture.md. Container-global
         store → thread-count=1. -->
    <test name="IntegrationV2-SecondaryUserStore" parallel="classes" thread-count="1">
        <parameter name="blockLabel" value="secondary-userstore"/>
        <parameter name="initTenantUsers" value="true"/>
        <parameter name="initSecondaryUserStore" value="true"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.AdminSecondaryUserStoreRunner"/>
        </classes>
    </test>
    <!-- Allowed-scopes enforcement: the container adds `[oauth] allowed_scopes` via a TOML overlay (the
         whitelist is container-global) and the flow invokes at the gateway, so the block runs thread-count=1
         and needs the backend. -->
    <test name="IntegrationV2-AllowedScopes" parallel="classes" thread-count="1">
        <parameter name="blockLabel" value="allowed-scopes"/>
        <parameter name="initTenantUsers" value="true"/>
        <parameter name="initBackend" value="true"/>
        <parameter name="tomlExtraOverlayPath" value="src/test/resources/artifacts/configFiles/allowedScopes/deployment.toml"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewayAllowedScopesRunner"/>
        </classes>
    </test>
    <!-- Application-tier change enforcement: no TOML overlay (bespoke low/high app policies are created via the
         admin API), but the app-throttle windows are time-sensitive and the tier-change+reset dance must not
         share a container with other time-sensitive throttle scenarios, so it runs in its own thread-count=1
         block. Needs the backend for runtime invocation. -->
    <test name="IntegrationV2-ApplicationTierChange" parallel="classes" thread-count="1">
        <parameter name="blockLabel" value="application-tier-change"/>
        <parameter name="initTenantUsers" value="true"/>
        <parameter name="initBackend" value="true"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewayApplicationTierChangeRunner"/>
        </classes>
    </test>
    <!-- Subscriptionless invocation: flips the container-global tenant-conf flag AllowSubscriptionValidationDisabling
         at runtime (captured + restored), so it runs in its own thread-count=1 block. No TOML overlay (tenant-conf is
         changed at runtime via the admin REST API). Needs the backend for runtime invocation. -->
    <test name="IntegrationV2-SubscriptionValidationDisable" parallel="classes" thread-count="1">
        <parameter name="blockLabel" value="subscription-validation-disable"/>
        <parameter name="initTenantUsers" value="true"/>
        <parameter name="initBackend" value="true"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.GatewaySubscriptionValidationDisableRunner"/>
        </classes>
    </test>
</suite>
