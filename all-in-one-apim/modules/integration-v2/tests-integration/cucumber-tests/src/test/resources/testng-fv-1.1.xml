<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  Isolated verification lane for the parallel-on-shared framework work.
  Holds only framework-verification probes (no server-flow tests) and is wired to NONE of the
  legacy listeners, so running it cannot affect the legacy testng.xml run.
-->
<suite name="Framework Verification 1.1" parallel="false">
    <test name="Phase1.1-SingleContainer">
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.verification.DynamicApimContainerVerificationTest"/>
        </classes>
    </test>
</suite>
