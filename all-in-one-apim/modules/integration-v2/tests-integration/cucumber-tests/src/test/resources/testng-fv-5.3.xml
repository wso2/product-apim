<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  Isolated verification lane (Phase 5.3): lifecycle provisioning lands in the freshly booted container.
  One block (Phase5.3-Provisioning) sets blockLabel=fv-5.3 and initTenantUsers=true with no tenantSet, so
  BlockLifecycleListener boots its DynamicApimContainer, gates on readiness, then provisions the DEFAULT
  tenant set (super tenant + tenant1.com + users testUser1/testUser11) into THIS block's own container
  during onStart. BlockProvisioningProbeRunner then asserts the provisioned beans are readable from the
  block's shared scope under the tenant-domain key, that CURRENT_TENANT resolves off them, and that the
  tenants/users actually exist in the live server (queried back via the legacy SOAP retrieve steps).
  parallel="false": a single block; nothing to overlap.
-->
<suite name="Framework Verification 5.3" parallel="false">
    <listeners>
        <listener class-name="org.wso2.am.integration.cucumbertests.utils.listeners.BlockLifecycleListener"/>
        <listener class-name="org.wso2.am.integration.cucumbertests.utils.listeners.BlockScopeListener"/>
    </listeners>
    <test name="Phase5.3-Provisioning">
        <parameter name="blockLabel" value="fv-5.3"/>
        <parameter name="initTenantUsers" value="true"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.BlockProvisioningProbeRunner"/>
        </classes>
    </test>
</suite>
