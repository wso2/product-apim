<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  Isolated verification lane (Phase 4.8): onFinish always releases, including on test FAILURE/ERROR.
  Two blocks run serially (parallel="false" => at most one container alive). Phase4.8-BlockFail boots a
  real container, the probe records its observation then deliberately FAILS; Phase4.8-BlockError boots a
  real container, the probe records then throws (ERROR). In both cases BlockLifecycleListener.onFinish
  must still stop the block container and release its dynamic host ports - teardown is not conditional on
  success/skip. Both blocks share the docker label block=fv-4.8 (distinct <test> names => distinct shared
  scopes). Wired to no legacy runners, so running it cannot affect the legacy testng.xml run.
-->
<suite name="Framework Verification 4.8" parallel="false">
    <listeners>
        <listener class-name="org.wso2.am.integration.cucumbertests.utils.listeners.BlockLifecycleListener"/>
        <listener class-name="org.wso2.am.integration.cucumbertests.utils.listeners.BlockScopeListener"/>
    </listeners>
    <test name="Phase4.8-BlockFail">
        <parameter name="blockLabel" value="fv-4.8"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.BlockProbeFailRunner"/>
        </classes>
    </test>
    <test name="Phase4.8-BlockError">
        <parameter name="blockLabel" value="fv-4.8"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.BlockProbeErrorRunner"/>
        </classes>
    </test>
</suite>
