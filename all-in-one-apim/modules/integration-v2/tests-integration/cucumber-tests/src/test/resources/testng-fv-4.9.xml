<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  Isolated verification lane (Phase 4.9): boot-failure isolation across parallel blocks. Suite runs
  parallel="tests" thread-count="2" over THREE blocks. Phase4.9-BlockBad points tomlOverlayPath at a
  nonexistent file, so its boot fails and its class FAILS (the guard rethrows the bootError as an
  IllegalStateException @BeforeClass config FAILURE, turning the build RED). Phase4.9-BlockGoodA and
  -BlockGoodB boot real containers and pass. The bad block's failure must NOT fail the good siblings or
  abort the suite - they still pass in isolation. All three share the docker label block=fv-4.9 (distinct
  <test> names => distinct shared scopes); the bad block creates no container. Wired to no legacy runners,
  so it cannot affect the legacy run.
-->
<suite name="Framework Verification 4.9" parallel="tests" thread-count="2">
    <listeners>
        <listener class-name="org.wso2.am.integration.cucumbertests.utils.listeners.BlockLifecycleListener"/>
        <listener class-name="org.wso2.am.integration.cucumbertests.utils.listeners.BlockScopeListener"/>
    </listeners>
    <test name="Phase4.9-BlockGoodA">
        <parameter name="blockLabel" value="fv-4.9"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.BlockProbeRunnerOne"/>
        </classes>
    </test>
    <test name="Phase4.9-BlockBad">
        <parameter name="blockLabel" value="fv-4.9"/>
        <parameter name="tomlOverlayPath" value="/nonexistent/fv-4.9/deployment.toml"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.BlockProbeRunnerTwo"/>
        </classes>
    </test>
    <test name="Phase4.9-BlockGoodB">
        <parameter name="blockLabel" value="fv-4.9"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.BlockProbeRunnerThree"/>
        </classes>
    </test>
</suite>
