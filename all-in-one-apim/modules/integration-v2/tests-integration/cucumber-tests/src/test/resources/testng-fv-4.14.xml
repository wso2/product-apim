<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  Isolated verification lane (Phase 4.14): parameter handling. Two blocks run serially (parallel="false").
  Phase4.14-Defaults sets NO tomlOverlayPath, so BlockLifecycleListener must fall back to the base
  deployment.toml and boot ready without NPE-ing on the absent overlay; its probe cat's the in-container
  toml and asserts the overlay marker is absent. Phase4.14-Overlay sets tomlOverlayPath to a generated toml
  carrying the marker; its probe cat's the in-container toml and asserts the marker is present - proving the
  parameter actually reached the running container. Both share the docker label block=fv-4.14 (distinct
  <test> names => distinct shared scopes). Wired to no legacy runners.

  The overlay file (target/fv-4.14-deployment.toml) is generated by verify-4.14.sh from the base toml plus
  the marker comment; the path resolves relative to the cucumber-tests module dir (surefire workdir).
-->
<suite name="Framework Verification 4.14" parallel="false">
    <listeners>
        <listener class-name="org.wso2.am.integration.cucumbertests.utils.listeners.BlockLifecycleListener"/>
        <listener class-name="org.wso2.am.integration.cucumbertests.utils.listeners.BlockScopeListener"/>
    </listeners>
    <test name="Phase4.14-Defaults">
        <parameter name="blockLabel" value="fv-4.14"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.BlockProbeDefaultsRunner"/>
        </classes>
    </test>
    <test name="Phase4.14-Overlay">
        <parameter name="blockLabel" value="fv-4.14"/>
        <parameter name="tomlOverlayPath" value="target/fv-4.14-deployment.toml"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.BlockProbeOverlayRunner"/>
        </classes>
    </test>
</suite>
