<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  PoC Phase 2 smoke: one all-in-one block booted by BlockLifecycleListener, plus the suite-level
  CoverageAggregationListener. Run with -Dapim.coverage=true to exercise the full wired path:
  withCoverage() on boot -> per-block .exec dump on finish -> suite-end merge + report.
  A single lightweight probe runner keeps it fast; wired to no legacy runners.
-->
<suite name="Coverage PoC Phase2 Smoke" parallel="false">
    <listeners>
        <listener class-name="org.wso2.am.integration.cucumbertests.utils.listeners.BlockLifecycleListener"/>
        <listener class-name="org.wso2.am.integration.cucumbertests.utils.listeners.BlockScopeListener"/>
        <listener class-name="org.wso2.am.integration.cucumbertests.utils.listeners.CoverageAggregationListener"/>
    </listeners>
    <test name="CovSmoke-Block" parallel="false">
        <parameter name="blockLabel" value="cov-smoke"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.BlockProbeRunnerOne"/>
        </classes>
    </test>
</suite>
