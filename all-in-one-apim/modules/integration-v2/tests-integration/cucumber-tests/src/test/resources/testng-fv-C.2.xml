<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  Isolated verification lane (Phase C.2): concurrent shared-scope write stress on TestContext. Type-A
  (no Docker, no block lifecycle): TestContextConcurrencyStressTest spins up many barrier-synchronized
  worker threads across many simulated block scopes that all hammer TestContext.setShared/get/addToList
  at the same instant, asserting no lost updates, no ConcurrentModification/ClassCast, and strict
  per-scope isolation under contention. The contention is internal to the test, so the suite itself runs
  parallel="false".
-->
<suite name="Framework Verification C.2" parallel="false">
    <test name="PhaseC.2-SharedScopeWriteStress">
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.verification.TestContextConcurrencyStressTest"/>
        </classes>
    </test>
</suite>
