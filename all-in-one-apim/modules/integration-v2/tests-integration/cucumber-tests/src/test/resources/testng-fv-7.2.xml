<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  Framework Verification 7.2/7.3/7.4/7.7/7.8 (consolidated): one block boot exercises the test-authoring
  framework features against the current model — tenancy provisioning+routing (7.2), the actor/Identity model
  with auth keys (7.3), multi-feature runner setup-handoff (7.4), gateway invocation wiring (7.7), and the
  extra-overlay merge (7.8). The block enables tenant users + backend + a feature-specific overlay; classes run
  sequentially (thread-count=1).
-->
<suite name="Framework Verification 7.2-7.8" parallel="tests" thread-count="1">
    <listeners>
        <listener class-name="org.wso2.am.integration.cucumbertests.utils.listeners.BlockLifecycleListener"/>
        <listener class-name="org.wso2.am.integration.cucumbertests.utils.listeners.BlockScopeListener"/>
    </listeners>
    <test name="IntegrationV2-FrameworkFeatures" parallel="classes" thread-count="1">
        <parameter name="blockLabel" value="framework-features"/>
        <parameter name="initTenantUsers" value="true"/>
        <parameter name="initBackend" value="true"/>
        <parameter name="tomlExtraOverlayPath" value="src/test/resources/artifacts/configFiles/frameworkFeatures/deployment.toml"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.FrameworkFeaturesProbeRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.FrameworkFeaturesHandoffRunner"/>
        </classes>
    </test>
</suite>
