<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  Isolated verification lane (Phase 1.3): full create -> deploy -> publish -> subscribe -> token ->
  invoke lifecycle through a DynamicApimContainer on dynamic ports. Registers only TestNameMdcListener
  so the shared TestContext scope resolves per invocation; wired to no legacy runners, so running it
  cannot affect the legacy testng.xml run.
-->
<suite name="Framework Verification 1.3" parallel="false">
    <listeners>
        <listener class-name="org.wso2.am.integration.cucumbertests.utils.listeners.TestNameMdcListener"/>
    </listeners>
    <test name="Phase1.3-DynamicLifecycle">
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.verification.DynamicLifecycleVerificationRunner"/>
        </classes>
    </test>
</suite>
