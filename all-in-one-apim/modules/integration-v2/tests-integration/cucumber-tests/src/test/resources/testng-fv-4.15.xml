<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  Isolated verification lane (Phase 4.15): mixed-lane co-existence. Because the listeners are suite-global,
  this one suite mixes BOTH execution models in two serial blocks (parallel="false"):

    - Phase4.15-Legacy sets NO blockLabel param. It drives the legacy fixed-port lane itself
      (SystemInitializationRunner boots its own APIMContainer + NodeApp and waits ready; SystemShutdown
      stops it). BlockLifecycleListener must OPT OUT for this block - i.e. no blockLabel => onStart/onFinish
      no-op, so the listener never boots a stray container for it nor disturbs its self-managed lifecycle.

    - Phase4.15-Lifecycle sets blockLabel=fv-4.15. BlockLifecycleListener boots the block's single
      DynamicApimContainer and the probe asserts readiness + shared URLs and records its observation.

  verify-4.15.sh proves the no-op: before the opt-in, the listener would have booted a fallback-labelled
  container block=Phase4.15-Legacy for the legacy block; after the opt-in no such container may exist. It
  also asserts exactly ONE observation (only the lifecycle probe records) across one real container id, and
  no fv-4.15 leak. Wired to no legacy testng.xml.
-->
<suite name="Framework Verification 4.15" parallel="false">
    <listeners>
        <listener class-name="org.wso2.am.integration.cucumbertests.utils.listeners.BlockLifecycleListener"/>
        <listener class-name="org.wso2.am.integration.cucumbertests.utils.listeners.BlockScopeListener"/>
    </listeners>
    <test name="Phase4.15-Legacy">
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.common.SystemInitializationRunner"/>
            <class name="org.wso2.am.integration.cucumbertests.runners.common.SystemShutdown"/>
        </classes>
    </test>
    <test name="Phase4.15-Lifecycle">
        <parameter name="blockLabel" value="fv-4.15"/>
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.runners.block.BlockProbeRunnerOne"/>
        </classes>
    </test>
</suite>
