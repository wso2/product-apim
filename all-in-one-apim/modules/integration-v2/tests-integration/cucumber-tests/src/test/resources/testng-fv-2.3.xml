<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  Isolated verification lane (Phase 2.3): no scope-map leak across many blocks. Registers only the NEW
  BlockScopeListener, so running it cannot affect the legacy testng.xml run. The single test
  orchestrates nested TestNG suites of many short blocks internally — no Docker required.
-->
<suite name="Framework Verification 2.3" parallel="false">
    <listeners>
        <listener class-name="org.wso2.am.integration.cucumbertests.utils.listeners.BlockScopeListener"/>
    </listeners>
    <test name="Phase2.3-NoScopeLeak">
        <classes>
            <class name="org.wso2.am.integration.cucumbertests.verification.BlockScopeLeakVerificationTest"/>
        </classes>
    </test>
</suite>
