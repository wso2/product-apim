<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>org.wso2.am</groupId>
        <artifactId>am-parent</artifactId>
        <version>4.7.0-SNAPSHOT</version>
        <relativePath>../../pom.xml</relativePath>
    </parent>

    <artifactId>integration-v2</artifactId>
    <name>WSO2 API Manager - Integration Tests 2</name>
    <version>4.7.0-SNAPSHOT</version>
    <packaging>pom</packaging>
    <modules>
        <module>tests-common</module>
        <module>tests-integration</module>
    </modules>

    <properties>
        <maven.compiler.source>21</maven.compiler.source>
        <maven.compiler.target>21</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <truststore.path>${user.dir}/client-truststore.jks</truststore.path>
        <truststore.password>wso2carbon</truststore.password>
        <keystore.path>${user.dir}/wso2carbon.jks</keystore.path>
        <keystore.password>wso2carbon</keystore.password>
        <wso2.host>localhost</wso2.host>
        <wso2.port>9443</wso2.port>
        <skipCertificateFetch>false</skipCertificateFetch>
        <!-- Shared DB defaults -->
        <shared.database.type>mysql</shared.database.type>
        <shared.database.driver>com.mysql.cj.jdbc.Driver</shared.database.driver>
        <shared.database.url>jdbc:mysql://host.docker.internal:3307/WSO2AM_COMMON_DB?allowPublicKeyRetrieval=true&amp;useSSL=false</shared.database.url>
        <shared.database.username>shared_user</shared.database.username>
        <shared.database.password>sharedpass</shared.database.password>
        <shared.database.validationQuery>SELECT 1</shared.database.validationQuery>

        <!-- APIM DB defaults -->
        <apim.database.type>mysql</apim.database.type>
        <apim.database.driver>com.mysql.cj.jdbc.Driver</apim.database.driver>
        <apim.database.url>jdbc:mysql://host.docker.internal:3306/WSO2AM_APIMGT_DB?allowPublicKeyRetrieval=true&amp;useSSL=false</apim.database.url>
        <apim.database.username>apim_user</apim.database.username>
        <apim.database.password>apimpass</apim.database.password>
        <apim.database.validationQuery>SELECT 1</apim.database.validationQuery>

        <!-- APIM server version: must match zip built by workflow (wso2am-${apim.server.version}.zip) -->
        <apim.server.version>4.7.0-SNAPSHOT</apim.server.version>
        <apim.server.name>wso2am-${apim.server.version}</apim.server.name>

        <!-- APIM docker image (jdk21 to align with workflow) -->
        <apim.docker.image.name>wso2am:${apim.server.version}-jdk21</apim.docker.image.name>
        <!--Node app servers docker image-->
        <node.docker.image.name>node-app-server:latest</node.docker.image.name>
        <!-- WSO2 Identity Server image used as an external Key Manager (integration-v2 external-KM block). -->
        <!-- WSO2 IS version used as the external key manager. 7.3.0 is multi-arch (native linux/arm64 and
             linux/amd64), so it boots natively on Apple-silicon dev machines and amd64 CI alike (7.1.0 was
             amd64-only, i.e. emulated/slow on arm64). Drives both the image tag and the in-container IS_HOME. -->
        <is.server.version>7.3.0</is.server.version>
        <is.docker.image.name>wso2/wso2is:${is.server.version}</is.docker.image.name>

        <!-- Debug API Manager instance-->
        <apim.debug.enabled>False</apim.debug.enabled>
        <apim.debug.port>5006</apim.debug.port>

        <!-- Integration coverage (opt-in): -Dapim.coverage=true attaches the JaCoCo agent to each block's
             container and renders a merged report at suite end. -Dapim.coverage.sources=<path> is an optional
             source tree (e.g. carbon-apimgt) for HTML line detail. Off/empty by default; default runs unaffected. -->
        <apim.coverage>false</apim.coverage>
        <apim.coverage.sources></apim.coverage.sources>

        <!-- Dependency versions (defined here so the integration-v2 reactor is self-contained) -->
        <testcontainers.version>2.0.2</testcontainers.version>
        <jackson.databind.version>2.16.1</jackson.databind.version>
        <jackson.dataformat.toml.version>2.17.1</jackson.dataformat.toml.version>
        <javax.ws.rs.version>2.1.1</javax.ws.rs.version>
        <glassfish.jaxb.version>2.3.1</glassfish.jaxb.version>
        <findbugs.jsr305.version>3.0.2</findbugs.jsr305.version>
        <apache.httpclient.version>4.5.14</apache.httpclient.version>
        <carbon.apimgt.api.version>9.31.94</carbon.apimgt.api.version>
        <carbon.utils.version>4.10.44</carbon.utils.version>
        <commons.io.version>2.18.0</commons.io.version>
        <commons.lang3.version>3.0</commons.lang3.version>
        <cucumber.version>7.0.0</cucumber.version>
        <cucumber.picocontainer.version>7.22.0</cucumber.picocontainer.version>
        <gson.version>2.10.1</gson.version>
        <json.version>20250107</json.version>
        <toml4j.version>0.7.2</toml4j.version>
        <org.skyscreamer.version>1.5.0</org.skyscreamer.version>
        <testng.version>7.4.0</testng.version>
    </properties>
    <dependencies>
        <dependency>
            <groupId>commons-logging</groupId>
            <artifactId>commons-logging</artifactId>
        </dependency>
        <dependency>
            <groupId>log4j</groupId>
            <artifactId>log4j</artifactId>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers</artifactId>
            <version>${testcontainers.version}</version>
        </dependency>
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-databind</artifactId>
            <version>${jackson.databind.version}</version>
        </dependency>
        <dependency>
            <groupId>com.fasterxml.jackson.dataformat</groupId>
            <artifactId>jackson-dataformat-toml</artifactId>
            <version>${jackson.dataformat.toml.version}</version>
        </dependency>
        <dependency>
            <groupId>javax.ws.rs</groupId>
            <artifactId>javax.ws.rs-api</artifactId>
            <version>${javax.ws.rs.version}</version>
            <scope>provided</scope>
        </dependency>
        <dependency>
            <groupId>org.glassfish.jaxb</groupId>
            <artifactId>jaxb-runtime</artifactId>
            <version>${glassfish.jaxb.version}</version>
        </dependency>
        <dependency>
            <groupId>com.google.code.findbugs</groupId>
            <artifactId>jsr305</artifactId>
            <version>${findbugs.jsr305.version}</version>
        </dependency>
        <dependency>
            <groupId>org.wso2.orbit.com.jayway.jsonpath</groupId>
            <artifactId>json-path</artifactId>
            <version>${com.jayway.jsonpath.version}</version>
        </dependency>
        <dependency>
            <groupId>net.minidev</groupId>
            <artifactId>json-smart</artifactId>
            <version>${json-smart.version}</version>
        </dependency>
    </dependencies>
    <profiles>
        <profile>
            <id>migration</id>
            <activation>
                <activeByDefault>false</activeByDefault>
                <property>
                    <name>migration</name>
                </property>
            </activation>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-surefire-plugin</artifactId>
                        <version>3.2.5</version>
                        <configuration>
                            <systemPropertyVariables>
                                <javax.net.ssl.trustStore>${truststore.path}</javax.net.ssl.trustStore>
                                <javax.net.ssl.trustStorePassword>${truststore.password}</javax.net.ssl.trustStorePassword>
                                <javax.net.ssl.keyStore>${keystore.path}</javax.net.ssl.keyStore>
                                <javax.net.ssl.keyStorePassword>${keystore.password}</javax.net.ssl.keyStorePassword>
                                <testcontainers.reuse.enable>true</testcontainers.reuse.enable>
                                <module.dir>${project.basedir}</module.dir>
                                <apim.server.name>${apim.server.name}</apim.server.name>
                                <apim.docker.image.name>${apim.docker.image.name}</apim.docker.image.name>
                                <node.docker.image.name>${node.docker.image.name}</node.docker.image.name>
                                <is.docker.image.name>${is.docker.image.name}</is.docker.image.name>
                                <is.server.version>${is.server.version}</is.server.version>
                                <apim.debug.enabled>${apim.debug.enabled}</apim.debug.enabled>
                                <apim.debug.port>${apim.debug.port}</apim.debug.port>
                                <apim.coverage>${apim.coverage}</apim.coverage>
                                <apim.coverage.sources>${apim.coverage.sources}</apim.coverage.sources>
                                <active.profile>migration</active.profile>
                            </systemPropertyVariables>
                            <environmentVariables>
                                <GATEWAY_ENVIRONMENT>Production and Sandbox</GATEWAY_ENVIRONMENT>
                                <APIM_TEST_CONTAINERS_PARALLEL_ENABLED>False</APIM_TEST_CONTAINERS_PARALLEL_ENABLED>
                                <PARALLEL_THREAD_COUNT>1</PARALLEL_THREAD_COUNT>

                                <SHARED_DATABASE_TYPE>${shared.database.type}</SHARED_DATABASE_TYPE>
                                <SHARED_DATABASE_DRIVER>${shared.database.driver}</SHARED_DATABASE_DRIVER>
                                <SHARED_DATABASE_URL>${shared.database.url}</SHARED_DATABASE_URL>
                                <SHARED_DATABASE_USERNAME>${shared.database.username}</SHARED_DATABASE_USERNAME>
                                <SHARED_DATABASE_PASSWORD>${shared.database.password}</SHARED_DATABASE_PASSWORD>
                                <SHARED_DATABASE_VALIDATION_QUERY>${shared.database.validationQuery}</SHARED_DATABASE_VALIDATION_QUERY>

                                <API_MANAGER_DATABASE_TYPE>${apim.database.type}</API_MANAGER_DATABASE_TYPE>
                                <API_MANAGER_DATABASE_DRIVER>${apim.database.driver}</API_MANAGER_DATABASE_DRIVER>
                                <API_MANAGER_DATABASE_URL>${apim.database.url}</API_MANAGER_DATABASE_URL>
                                <API_MANAGER_DATABASE_USERNAME>${apim.database.username}</API_MANAGER_DATABASE_USERNAME>
                                <API_MANAGER_DATABASE_PASSWORD>${apim.database.password}</API_MANAGER_DATABASE_PASSWORD>
                                <API_MANAGER_DATABASE_VALIDATION_QUERY>${apim.database.validationQuery}</API_MANAGER_DATABASE_VALIDATION_QUERY>
                            </environmentVariables>
                        </configuration>
                    </plugin>

                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-compiler-plugin</artifactId>
                        <version>3.8.1</version>
                        <configuration>
                            <source>11</source>
                            <target>11</target>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>
        <profile>
            <id>default</id>
            <activation>
                <activeByDefault>true</activeByDefault>
                <property>
                    <name>default</name>
                </property>
            </activation>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-surefire-plugin</artifactId>
                        <version>3.2.5</version>
                        <configuration>
                            <systemPropertyVariables>
                                <javax.net.ssl.trustStore>${truststore.path}</javax.net.ssl.trustStore>
                                <javax.net.ssl.trustStorePassword>${truststore.password}</javax.net.ssl.trustStorePassword>
                                <javax.net.ssl.keyStore>${keystore.path}</javax.net.ssl.keyStore>
                                <javax.net.ssl.keyStorePassword>${keystore.password}</javax.net.ssl.keyStorePassword>
                                <testcontainers.reuse.enable>true</testcontainers.reuse.enable>
                                <module.dir>${project.basedir}</module.dir>
                                <apim.server.name>${apim.server.name}</apim.server.name>
                                <apim.docker.image.name>${apim.docker.image.name}</apim.docker.image.name>
                                <node.docker.image.name>${node.docker.image.name}</node.docker.image.name>
                                <is.docker.image.name>${is.docker.image.name}</is.docker.image.name>
                                <is.server.version>${is.server.version}</is.server.version>
                                <apim.debug.enabled>${apim.debug.enabled}</apim.debug.enabled>
                                <apim.debug.port>${apim.debug.port}</apim.debug.port>
                                <apim.coverage>${apim.coverage}</apim.coverage>
                                <apim.coverage.sources>${apim.coverage.sources}</apim.coverage.sources>
                                <active.profile>default</active.profile>
                            </systemPropertyVariables>
                            <environmentVariables>
                                <GATEWAY_ENVIRONMENT>Default</GATEWAY_ENVIRONMENT>
                                <APIM_TEST_CONTAINERS_PARALLEL_ENABLED>True</APIM_TEST_CONTAINERS_PARALLEL_ENABLED>
                                <PARALLEL_THREAD_COUNT>2</PARALLEL_THREAD_COUNT>

                                <SHARED_DATABASE_TYPE>h2</SHARED_DATABASE_TYPE>
                                <SHARED_DATABASE_DRIVER>org.h2.Driver</SHARED_DATABASE_DRIVER>
                                <SHARED_DATABASE_URL>
                                    jdbc:h2:./repository/database/WSO2SHARED_DB;DB_CLOSE_ON_EXIT=FALSE
                                </SHARED_DATABASE_URL>
                                <SHARED_DATABASE_USERNAME>wso2carbon</SHARED_DATABASE_USERNAME>
                                <SHARED_DATABASE_PASSWORD>wso2carbon</SHARED_DATABASE_PASSWORD>
                                <SHARED_DATABASE_VALIDATION_QUERY>SELECT 1</SHARED_DATABASE_VALIDATION_QUERY>

                                <API_MANAGER_DATABASE_TYPE>h2</API_MANAGER_DATABASE_TYPE>
                                <API_MANAGER_DATABASE_DRIVER>org.h2.Driver</API_MANAGER_DATABASE_DRIVER>
                                <API_MANAGER_DATABASE_URL>
                                    jdbc:h2:./repository/database/WSO2AM_DB;DB_CLOSE_ON_EXIT=FALSE
                                </API_MANAGER_DATABASE_URL>
                                <API_MANAGER_DATABASE_USERNAME>wso2carbon</API_MANAGER_DATABASE_USERNAME>
                                <API_MANAGER_DATABASE_PASSWORD>wso2carbon</API_MANAGER_DATABASE_PASSWORD>
                                <API_MANAGER_DATABASE_VALIDATION_QUERY>SELECT 1</API_MANAGER_DATABASE_VALIDATION_QUERY>
                            </environmentVariables>
                        </configuration>
                    </plugin>

                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-compiler-plugin</artifactId>
                        <version>3.8.1</version>
                        <configuration>
                            <source>11</source>
                            <target>11</target>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>
</project>
