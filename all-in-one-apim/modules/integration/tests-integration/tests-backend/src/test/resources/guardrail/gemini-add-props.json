{
  "name": "geminiAPI",
  "version": "1.0.0",
  "context": "geminiAPI",
  "gatewayType": "wso2/synapse",
  "policies": ["Unlimited"],
  "endpointConfig": {
    "endpoint_type": "http",
    "endpoint_security": {
      "production": {
        "enabled": true,
        "type": "apikey",
        "apiKeyIdentifier": "Authorization",
        "apiKeyValue": "Bearer test-gemini-key",
        "apiKeyIdentifierType": "HEADER",
        "username": "",
        "password": "",
        "grantType": "",
        "tokenUrl": "",
        "clientId": null,
        "clientSecret": null,
        "customParameters": "{}"
      }
    }
  },
  "subtypeConfiguration": {
    "subtype": "AIAPI",
    "configuration": {
      "llmProviderName": "Gemini",
      "llmProviderApiVersion": "v1"
    }
  },
  "securityScheme": ["api_key"],
  "egress": true
}
